          strokeAnts(0, 0, (c) => {
            const cx = (draftBounds.sx + draftBounds.ex) / 2;
            const cy = (draftBounds.sy + draftBounds.ey) / 2;
            const rx = Math.abs(draftBounds.ex - draftBounds.sx) / 2;
            const ry = Math.abs(draftBounds.ey - draftBounds.sy) / 2;
