            const chain = smoothChain(rawChain);
            if (chain.length < 2) continue;
            c.moveTo(chain[0][0], chain[0][1]);
            for (let ci = 1; ci < chain.length; ci++) {
              c.lineTo(chain[ci][0], chain[ci][1]);
            }
