    const afterSnap = snapshotSelection();
    pushHistory({
      type: "selection",
      before: selectionBeforeRef.current ?? afterSnap,
      after: afterSnap,
    });
    selectionBeforeRef.current = null;

    // If a transform is currently active, update the bounding box to match the new mask
