      const sb = selectionDraftBoundsRef.current;
      if (sb) {
        const x = Math.min(sb.sx, sb.ex);
        const y = Math.min(sb.sy, sb.ey);
        const w = Math.abs(sb.ex - sb.sx);
        const h = Math.abs(sb.ey - sb.sy);
