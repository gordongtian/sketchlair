          const ob = moveFloatOriginBoundsRef.current;
          if (xfAnts && ob) {
            const bx = xfAnts.x;
            const by = xfAnts.y;
            const bw = xfAnts.w;
            const bh = xfAnts.h;
            const ocx = bx + bw / 2;
            const ocy = by + bh / 2;
